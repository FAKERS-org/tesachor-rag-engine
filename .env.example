# Leave empty unless you explicitly use provider endpoints like Featherless
HF_LLM_PROVIDER=
FEATHERLESS_API_KEY=
# hf read-only token for embedding and LLM models
HF_API_TOKEN=YOUR_HF_API_TOKEN_HERE

# Fast iteration config
# EMBEDDING_MODEL = "sentence-transformers/all-MiniLM-L6-v2"  # 384 dim
# LLM_MODEL = "TinyLlama/TinyLlama-1.1B-Chat-v1.0"  # 1.1B params

EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
# Free serverless model aliases: qwen2.5-7b, llama-3.2-1b
LLM_MODEL=qwen2.5-7b
HF_LLM_ENDPOINT=
VECTOR_DB_PATH=./data/vector_db
POSTGRES_URL=YOUR_POSTGRES_URL_HERE
REDIS_URL=redis://localhost:6379/0

# seed data
DATASET_DIR=./data/transformed